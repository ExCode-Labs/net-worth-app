# ── Backend ───────────────────────────────────────────────────────────────────
# Base URL for the NestJS API server
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Google Sign-In (useSignInWithGoogle from @clerk/expo/google) ─────────────
# Requires a custom dev build (NOT Expo Go). Uses Clerk's native module.
# Get from: Google Cloud Console → APIs & Services → OAuth 2.0 Client IDs
# 1. Create a "Web application" client → copy the Client ID here
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com
# 2. (iOS only) Create an "iOS" client (bundle ID: com.excodelabs.networth) → copy here
EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=xxxxxxxxxxxxxxxx.apps.googleusercontent.com
