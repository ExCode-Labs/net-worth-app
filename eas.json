{
  "cli": {
    "version": ">= 19.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://net-worth-api-beta.vercel.app",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "647898738704-m7e1nhod869hoa46l62bpp9r9l9g2t7q.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_APP_CLIENT_ID": "647898738704-bfjdh64o3osml9171olacf7jvdg2h711.apps.googleusercontent.com"
      }
    },
    "production": {
      "autoIncrement": true
    },
    "production-apk": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.networth.excodelabs.com",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "647898738704-m7e1nhod869hoa46l62bpp9r9l9g2t7q.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_APP_CLIENT_ID": "647898738704-bfjdh64o3osml9171olacf7jvdg2h711.apps.googleusercontent.com"
      }
    },
    "production-apk-arm64": {
      "extends": "production-apk",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
